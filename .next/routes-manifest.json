{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/passes/v1/devices/[deviceLibraryIdentifier]/registrations/[passTypeIdentifier]",
      "regex": "^/api/passes/v1/devices/([^/]+?)/registrations/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPdeviceLibraryIdentifier": "nxtPdeviceLibraryIdentifier",
        "nxtPpassTypeIdentifier": "nxtPpassTypeIdentifier"
      },
      "namedRegex": "^/api/passes/v1/devices/(?<nxtPdeviceLibraryIdentifier>[^/]+?)/registrations/(?<nxtPpassTypeIdentifier>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/passes/v1/devices/[deviceLibraryIdentifier]/registrations/[passTypeIdentifier]/[serialNumber]",
      "regex": "^/api/passes/v1/devices/([^/]+?)/registrations/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPdeviceLibraryIdentifier": "nxtPdeviceLibraryIdentifier",
        "nxtPpassTypeIdentifier": "nxtPpassTypeIdentifier",
        "nxtPserialNumber": "nxtPserialNumber"
      },
      "namedRegex": "^/api/passes/v1/devices/(?<nxtPdeviceLibraryIdentifier>[^/]+?)/registrations/(?<nxtPpassTypeIdentifier>[^/]+?)/(?<nxtPserialNumber>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/passes/v1/passes/[passTypeIdentifier]/[serialNumber]",
      "regex": "^/api/passes/v1/passes/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPpassTypeIdentifier": "nxtPpassTypeIdentifier",
        "nxtPserialNumber": "nxtPserialNumber"
      },
      "namedRegex": "^/api/passes/v1/passes/(?<nxtPpassTypeIdentifier>[^/]+?)/(?<nxtPserialNumber>[^/]+?)(?:/)?$"
    },
    {
      "page": "/order/[id]",
      "regex": "^/order/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/order/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/loyalty",
      "regex": "^/loyalty(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/loyalty(?:/)?$"
    },
    {
      "page": "/terminal",
      "regex": "^/terminal(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terminal(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}